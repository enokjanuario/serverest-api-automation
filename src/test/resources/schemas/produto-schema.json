{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Produto",
  "type": "object",
  "properties": {
    "nome": { "type": "string" },
    "preco": { "type": "integer" },
    "descricao": { "type": "string" },
    "quantidade": { "type": "integer" },
    "_id": { "type": "string" }
  },
  "required": ["nome", "preco", "descricao", "quantidade", "_id"],
  "additionalProperties": false
}
