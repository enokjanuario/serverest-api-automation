{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Usuario",
  "description": "Schema for a single user returned by GET /usuarios/{_id}",
  "type": "object",
  "properties": {
    "nome": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "password": {
      "type": "string"
    },
    "administrador": {
      "type": "string"
    },
    "_id": {
      "type": "string"
    }
  },
  "required": ["nome", "email", "password", "administrador", "_id"],
  "additionalProperties": false
}
